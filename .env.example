# ============================================================================
# JARVIS Portable — Exemple de configuration (copier en .env)
#
# Usage :
#   Windows : copy .env.example .env
#   Linux/macOS : cp .env.example .env
#
# Toutes les valeurs sont optionnelles : JARVIS démarre avec ces defauts
# si le fichier .env est absent. Les launchers (JARVIS.bat / .sh) posent
# deja OLLAMA_HOST et OLLAMA_MODELS avant de lancer Python.
# ============================================================================

# --- API JARVIS ---
# Port de l'interface web / API REST
JARVIS_PORT=8000
# Niveau de log : DEBUG, INFO, WARNING, ERROR
JARVIS_LOG_LEVEL=INFO
# Mode dev (stack traces detaillees, messages verbeux)
JARVIS_DEV=false
# Profil low I/O / low VRAM : cache vectoriel reduit, moins de resultats
# (cle USB lente ou peu de RAM)
JARVIS_LOW_IO=false

# --- OpenWebUI (interface web alternative, port 3000) ---
# Opt-in strict : doit valoir "1" pour demarrer. Par defaut desactive
# (un outil de diagnostic reste minimaliste). Ne demarre que si installe.
JARVIS_ENABLE_OPENWEBUI=0

# --- Tableau de bord beta (route /api/beta_dashboard) ---
JARVIS_BETA_DASHBOARD=0

# --- Profiling des endpoints lents (secondes) ---
JARVIS_SLOW_THRESHOLD=1.0

# --- Controle d'acces aux fichiers ---
# Recommande : borne le sandbox aux chemins que l'utilisateur autorise.
# Si vide, l'utilisateur peut autoriser n'importe quel dossier.
# JARVIS_FILES_SANDBOX_ROOT=C:\Projet-JARVIS\allowed_files

# --- Backend Ollama portable (poses par les launchers, reserves ici) ---
# OLLAMA_HOST=127.0.0.1:11436
# OLLAMA_MODELS=models/ollama
